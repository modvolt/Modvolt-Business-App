# ---------------------------------------------------------------------------
# Modvolt Knowledge - příklad konfigurace prostředí
# Zkopíruj do .env a vyplň hodnoty. Veškerá konfigurace je přes env proměnné.
# ---------------------------------------------------------------------------

# --- Povinné ---
DATABASE_URL=postgres://user:password@host:5432/modvolt_knowledge
SESSION_SECRET=zmen-me-na-dlouhy-nahodny-retezec
APP_BASE_URL=http://localhost:3000

# --- S3 / Hetzner Object Storage ---
# Soubory se ukládají do privátního S3 bucketu, nikdy ne přes veřejné URL.
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_PUBLIC_ENDPOINT=
S3_REGION=fsn1
S3_BUCKET=modvolt-knowledge
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# --- OpenAI ---
# Aplikace funguje i bez OpenAI - AI funkce jsou pak vypnuté.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_ENABLED=false
OPENAI_IMAGE_ANALYSIS_ENABLED=false
OPENAI_MAX_CONTEXT_CHUNKS=8
OPENAI_MAX_UPLOAD_MB=50
OPENAI_REQUEST_TIMEOUT_MS=60000

# --- Fotografie ---
MAX_IMAGE_UPLOAD_MB=15
STRIP_IMAGE_EXIF=true

# --- Web search (volitelné) ---
# Aplikace funguje i bez web search provideru.
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_MS=10000

# --- Admin bootstrap (pro npm run db:seed-admin) ---
ADMIN_EMAIL=admin@modvolt.cz
ADMIN_PASSWORD=zmen-me-po-prvnim-prihlaseni
ADMIN_NAME=Administrátor

# --- Volitelné ---
LOG_LEVEL=info
NODE_ENV=production
PORT=3000
