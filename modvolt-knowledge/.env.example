# ---------------------------------------------------------------------------
# Modvolt Knowledge - příklad konfigurace prostředí
# Zkopíruj do .env a vyplň hodnoty. Veškerá konfigurace je přes env proměnné.
# ---------------------------------------------------------------------------

# --- Povinné ---
DATABASE_URL=postgres://user:password@host:5432/modvolt_knowledge
SESSION_SECRET=zmen-me-na-dlouhy-nahodny-retezec
APP_BASE_URL=http://localhost:3000

# --- Session cookie ---
# Pro běžné nasazení na vlastní doméně ponech výchozí (lax). Secure se zapne
# automaticky v produkci (NODE_ENV=production). Tyto proměnné měň jen pokud
# aplikaci vkládáš do cross-site iframe – pak nastav none + true.
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=false

# --- S3 / Hetzner Object Storage ---
# Soubory se ukládají do privátního S3 bucketu, nikdy ne přes veřejné URL.
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_PUBLIC_ENDPOINT=
S3_REGION=fsn1
S3_BUCKET=modvolt-knowledge
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# --- OpenAI ---
# Aplikace funguje i bez OpenAI - AI funkce jsou pak vypnuté.
# Jeden klíč pro všechny modely (chat, klasifikaci, embeddingy i vizi).
OPENAI_API_KEY=
OPENAI_ENABLED=false
# Volitelný OpenAI-kompatibilní endpoint (pro jiného poskytovatele).
# Prázdné = výchozí https://api.openai.com.
OPENAI_BASE_URL=
# Jeden chat model obsluhuje chat, klasifikaci i popis fotek (pro analýzu
# obrázků musí být multimodální). Embeddingy vyžadují samostatný embedding
# model - chat model embeddingy spočítat neumí.
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_IMAGE_ANALYSIS_ENABLED=false
OPENAI_MAX_CONTEXT_CHUNKS=8
OPENAI_MAX_UPLOAD_MB=50
OPENAI_REQUEST_TIMEOUT_MS=60000

# --- Fotografie ---
MAX_IMAGE_UPLOAD_MB=15
STRIP_IMAGE_EXIF=true

# --- Web search (volitelné) ---
# Aplikace funguje i bez web search provideru.
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_MS=10000

# --- Admin bootstrap (pro npm run db:seed-admin) ---
ADMIN_EMAIL=admin@modvolt.cz
ADMIN_PASSWORD=zmen-me-po-prvnim-prihlaseni
ADMIN_NAME=Administrátor

# --- Volitelné ---
LOG_LEVEL=info
NODE_ENV=production
PORT=3000
