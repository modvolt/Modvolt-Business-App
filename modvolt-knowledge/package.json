{
  "name": "modvolt-knowledge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Modvolt Knowledge - interní znalostní databáze s AI a RAG nad firemními dokumenty",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild src/server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/server/index.js",
    "start": "node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate-cli.ts",
    "db:seed-admin": "tsx src/server/db/seed-admin-cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --experimental-test-module-mocks --test \"src/server/**/*.test.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@hyzyla/pdfium": "^2.1.13",
    "@tanstack/react-query": "^5.59.0",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "helmet": "^8.2.0",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "sharp": "^0.33.5",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "drizzle-kit": "^0.28.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
